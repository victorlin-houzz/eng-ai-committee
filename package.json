    "jszip": "^3.10.1",
    "mammoth": "^1.12.0",
    "markdown-it": "^14",
    "multer": "^2",
    "openai": "^6.34.0",
    "ora": "^8",
    "pdf-parse": "^1.1.1",
    "pdfjs-dist": "^5.6.205",
    "pdfkit": "^0.15",
    "socket.io": "^4",
    "socket.io-client": "^4",
    "uuid": "^9"
  },
  "devDependencies": {
    "@codemirror/lang-markdown": "^6",
    "@codemirror/state": "^6",
    "@codemirror/theme-one-dark": "^6",
    "@codemirror/view": "^6",
    "@types/express": "^4",
    "@types/markdown-it": "^14",
    "@types/multer": "^1",
    "@types/node": "^20",
    "@types/pdf-parse": "^1.1.4",
    "@types/pdfkit": "^0.13",
