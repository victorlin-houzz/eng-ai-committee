{
  "name": "eng-ai-committee",
  "version": "0.1.0",
  "description": "Multi-agent design doc review gate for engineering committees",
  "license": "MIT",
  "type": "module",
  "bin": {
    "review-gate": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
